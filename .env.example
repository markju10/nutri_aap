# ─── Database ────────────────────────────────────────────────────────────────
# Railway fornisce questa variabile automaticamente quando aggiungi il plugin MySQL
DATABASE_URL=mysql://user:password@host:3306/nutriai

# ─── Autenticazione JWT ───────────────────────────────────────────────────────
# Genera una stringa casuale sicura (es. openssl rand -hex 32)
JWT_SECRET=cambia-questa-stringa-con-una-sicura-e-casuale

# ─── OpenAI (OBBLIGATORIO per AI Vision e generazione ricette) ────────────────
# Ottieni la chiave su https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Modello da usare (gpt-4o è il migliore per Vision, gpt-4o-mini è più economico)
OPENAI_MODEL=gpt-4o

# ─── Cloudinary (OPZIONALE - per salvare le foto del cibo) ───────────────────
# Crea un account gratuito su https://cloudinary.com (25GB gratuiti)
# Se non configurato, le foto vengono analizzate ma non salvate permanentemente
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=production
APP_URL=https://tuo-progetto.up.railway.app
